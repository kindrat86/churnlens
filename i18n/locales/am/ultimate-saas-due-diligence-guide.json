  "__TR_ultimate-saas-due-diligence-guide_8__": "የሞባይል አሰሳ",
  "__TR_ultimate-saas-due-diligence-guide_9__": "ወደ ላይ ተመለስ",
  "__TR_ultimate-saas-due-diligence-guide_10__": "Churn Lens",
  "__TR_ultimate-saas-due-diligence-guide_11__": "ዋጋ አሰጣጥ",
  "__TR_ultimate-saas-due-diligence-guide_12__": "የመስራች ታሪክ",
  "__TR_ultimate-saas-due-diligence-guide_13__": "ማኒፌስቶ",
  "__TR_ultimate-saas-due-diligence-guide_14__": "አጋሮች",
  "__TR_ultimate-saas-due-diligence-guide_15__": "የማረጋገጫ ዝርዝሩን ያግኙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_16__": "መነሻ ገጽ",
  "__TR_ultimate-saas-due-diligence-guide_17__": "ዋጋ አሰጣጥ",
  "__TR_ultimate-saas-due-diligence-guide_18__": "የመስራች ታሪክ",
  "__TR_ultimate-saas-due-diligence-guide_19__": "የማረጋገጫ ዝርዝሩን ያግኙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_20__": "ነፃ የማረጋገጫ ዝርዝሩን ያግኙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_21__": "የመጨረሻው የSaaS ተገቢ ትጋት",
  "__TR_ultimate-saas-due-diligence-guide_22__": "መመሪያ (2026)",
  "__TR_ultimate-saas-due-diligence-guide_23__": "የ23-ነጥብ የተጠቃሚ መሰናበቻ ኦዲት ዝርዝር ያግኙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_24__": "ይህን መመሪያ እንዴት መጠቀም እንደሚቻል፦",
  "__TR_ultimate-saas-due-diligence-guide_25__": "ከታች ያለው እያንዳንዱ ክፍል ወሳኝ ልኬትን ይሸፍናል",
  "__TR_ultimate-saas-due-diligence-guide_26__": "የተጠቃሚ መሰናበቻን መረዳት",
  "__TR_ultimate-saas-due-diligence-guide_27__": "በገዢ ወገን አዲስ ከሆኑ",
  "__TR_ultimate-saas-due-diligence-guide_28__": "የ23-ነጥብ የተጠቃሚ መሰናበቻ ኦዲት ዝርዝር",
  "__TR_ultimate-saas-due-diligence-guide_29__": "17+",
  "__TR_ultimate-saas-due-diligence-guide_30__": "የባለሙያ ሀብቶች",
  "__TR_ultimate-saas-due-diligence-guide_31__": "ዋና ክፍሎች",
  "__TR_ultimate-saas-due-diligence-guide_32__": "የኦዲት ዝርዝር ነጥቦች",
  "__TR_ultimate-saas-due-diligence-guide_33__": "የተዘመኑ መለኪያዎች",
  "__TR_ultimate-saas-due-diligence-guide_34__": "የSaaS የተጠቃሚ መሰናበቻ መጠን መለኪያዎች በኢንዱስትሪ",
  "__TR_ultimate-saas-due-diligence-guide_35__": "ማንኛውንም ኢላማ በ14 የSaaS ዘርፎች ውስጥ ከኢንዱስትሪ አማካይ ወርሃዊ መሰናበቻ፣ ዓመታዊ መሰናበቻ እና የምርት ስም ማቆያ ጋር ያወዳድሩ።",
  "__TR_ultimate-saas-due-diligence-guide_36__": "መለኪያዎችን ያንብቡ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_37__": "የተደበቀ የተጠቃሚ መሰናበቻ፦ ሻጮች የማይነግሩዎት ነገር",
  "__TR_ultimate-saas-due-diligence-guide_38__": "የSaaS ሻጮች የተጠቃሚ መሰናበቻን ከሚመስለው የተሻለ ለማስመሰል የሚጠቀሙባቸው 7 ዘዴዎች፣ ከሙከራ ዳግም ምደባ እስከ ቡድን ምርጫ አድልዎ ድረስ።",
  "__TR_ultimate-saas-due-diligence-guide_39__": "የተደበቀ መሰናበቻን ያጋልጡ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_40__": "የSaaS የገቢ መሰናበቻ አስሊ",
  "__TR_ultimate-saas-due-diligence-guide_41__": "ነፃ መሳሪያ፦ ወርሃዊ መሰናበቻ፣ ዓመታዊ መሰናበቻ፣ NRR፣ GRR፣ የምርት ስም ማቆያ እና ከመሰናበቻ የተስተካከለ MRR ከእርስዎ መረጃ ያሰሉ።",
  "__TR_ultimate-saas-due-diligence-guide_42__": "አስሊውን ይጠቀሙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_43__": "የምርት ስም ማቆያ ከገቢ መሰናበቻ ጋር",
  "__TR_ultimate-saas-due-diligence-guide_44__": "እነዚህ ሁለት መለኪያዎች የሚለያዩበት ምክንያት &mdash; እና ክፍተቱ ራሱ ገዢ ሊያውቀው የሚችለው በጣም አስፈላጊ ምልክት የሆነው።",
  "__TR_ultimate-saas-due-diligence-guide_45__": "ልዩነቱን ይማሩ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_46__": "MRR ከገቢ ጥራት ጋር",
  "__TR_ultimate-saas-due-diligence-guide_47__": "ጥሬ MRR አሳሳች ሊሆን ይችላል። የገቢ ጥራት ውጤቶች ያ MRR በ12 ወራት ውስጥ አሁንም እንደሚኖር ያሳያሉ።",
  "__TR_ultimate-saas-due-diligence-guide_48__": "መለኪያዎችን ያወዳድሩ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_49__": "በSaaS ውስጥ የደንበኛ ማከማቸት አደጋ",
  "__TR_ultimate-saas-due-diligence-guide_50__": "3 ደንበኞች ከMRR 60%+ ሲወክሉ ምን ይከሰታል። የማከማቸት አደጋን እንዴት መለየት እና ዋጋ መስጠት እንደሚቻል።",
  "__TR_ultimate-saas-due-diligence-guide_51__": "ማከማቸትን ይተንትኑ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_52__": "የSaaS የገቢ ማከማቸት አደጋ",
  "__TR_ultimate-saas-due-diligence-guide_53__": "የሄርፊንዳል-ሂርሽማን ኢንዴክስ (HHI) አቀራረብን ጨምሮ ወደ ገቢ ማከማቸት ጥልቅ ዳይቭ።",
  "__TR_ultimate-saas-due-diligence-guide_54__": "የገቢ አደጋን ይገምግሙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_55__": "የዓመታዊ እቅድ የተጠቃሚ መሰናበቻ አደጋ ትንተና",
  "__TR_ultimate-saas-due-diligence-guide_56__": "ቀደም ብለው የሚሰረዙ የዓመታዊ እቅድ ደንበኞች በወርሃዊ የመሰናበቻ ሪፖርቶች የማይታይ የገቢ \"ገደል\" ይፈጥራሉ። እንዴት እንደሚታወቅ እነሆ።",
  "__TR_ultimate-saas-due-diligence-guide_57__": "የእቅድ አደጋን ይገምግሙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_58__": "የማይንቀሳቀሱ የሚከፈልባቸው መለያዎች — ጸጥ ያለ መሰናበቻ",
  "__TR_ultimate-saas-due-diligence-guide_59__": "አሁንም የሚከፍሉ ግን የማይሳተፉ ደንበኞች። ዞምቢ MRR በP&amp;L ላይ የተረጋጋ ይመስላል ነገር ግን ከዝጋት በኋላ በአንድ ኢንቮይስ ይጠፋል።",
  "__TR_ultimate-saas-due-diligence-guide_60__": "ዞምቢ MRR ያግኙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_61__": "ለገዢዎች የMRR ማሽቆልቆል ትንተና",
  "__TR_ultimate-saas-due-diligence-guide_62__": "የMRR አዝማሚያዎችን እንዴት መተንተን፣ የተደበቀ ማሽቆልቆልን መለየት እና በኢላማው የደንበኝነት ምዝገባ መረጃ ውስጥ እድገትን ከቡድን መበስበስ መለየት እንደሚቻል።",
  "__TR_ultimate-saas-due-diligence-guide_63__": "የMRR አዝማሚያዎችን ይተንትኑ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_64__": "የSaaS የገቢ ጥራት ውጤት ተብራርቷል",
  "__TR_ultimate-saas-due-diligence-guide_65__": "ማቆያ፣ ማከማቸት፣ የማስፋፊያ ገቢ እና የእድገት አዝማሚያዎችን የሚመዝን የተቀናጀ A&ndash;F ደረጃ። አንድ የፊደል ደረጃ ከ50-ገጽ CIM የበለጠ ይነግርዎታል።",
  "__TR_ultimate-saas-due-diligence-guide_66__": "RQS ይረዱ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_67__": "ነፃ የገዢ-ወገን የአደጋ ግምገማ",
  "__TR_ultimate-saas-due-diligence-guide_68__": "ማንኛውንም የSaaS ግዢ ኢላማ ቅናሽ ከማቅረብዎ በፊት ለመገምገም የተዋቀረ የአደጋ ግምገማ ማዕቀፍ።",
  "__TR_ultimate-saas-due-diligence-guide_69__": "ግምገማውን ያካሂዱ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_70__": "MRR ከገቢ ጥራት ጋር",
  "__TR_ultimate-saas-due-diligence-guide_71__": "ተመሳሳይ MRR ያላቸው ሁለት ኢላማዎች በከፍተኛ ሁኔታ የተለያየ እውነተኛ ዋጋ ሊኖራቸው የሚችለው ለምንድነው &mdash; እና እንዴት መለየት እንደሚቻል።",
  "__TR_ultimate-saas-due-diligence-guide_72__": "ጥራትን ያወዳድሩ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_73__": "የSaaS የገቢ መሰናበቻ አስሊ",
  "__TR_ultimate-saas-due-diligence-guide_74__": "NRR፣ GRR፣ ከመሰናበቻ የተስተካከለ MRR እና ዓመታዊ ተመኖችን ከኢላማዎ ጥሬ መረጃ ለማስላት ነፃ መሳሪያ።",
  "__TR_ultimate-saas-due-diligence-guide_75__": "መሰናበቻን ያስሉ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_76__": "የSaaS ንግድ ለመግዛት የተሟላ መመሪያ",
  "__TR_ultimate-saas-due-diligence-guide_77__": "ለ2026 የSaaS ግዢዎች የስምምነት ምንጭ ፍለጋ፣ ዋጋ አሰጣጥ፣ ተገቢ ትጋት፣ ድርድር እና ከዝጋት በኋላ ውህደትን የሚሸፍን ከጫፍ እስከ ጫፍ የአጨዋወት መጽሐፍ።",
  "__TR_ultimate-saas-due-diligence-guide_78__": "መመሪያውን ያንብቡ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_79__": "የተሟላ የSaaS ተገቢ ትጋት ዝርዝር",
  "__TR_ultimate-saas-due-diligence-guide_80__": "ከፋይናንስ እና የተጠቃሚ መሰናበቻ እስከ ህጋዊ፣ ቴክኖሎጂ እና የቡድን ትጋት ድረስ ሁሉንም የሚሸፍን ሊታተም የሚችል ዝርዝር &mdash; ገዢ ማረጋገጥ ያለበት እያንዳንዱ ሳጥን።",
  "__TR_ultimate-saas-due-diligence-guide_81__": "የማረጋገጫ ዝርዝሩን ያግኙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_82__": "የSaaS ግዢ ቀይ ባንዲራዎች",
  "__TR_ultimate-saas-due-diligence-guide_83__": "ስምምነትን ሊያቆሙ ወይም ዋጋውን ሊቀይሩ የሚገባቸው 15 ቀይ ባንዲራዎች፣ ከ\"ከመሰናበቻ ማደግ\" እስከ በCIM ውስጥ አጠራጣሪ የቡድን ምርጫ ድረስ።",
  "__TR_ultimate-saas-due-diligence-guide_84__": "ቀይ ባንዲራዎችን ይለዩ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_85__": "ከመግዛትዎ በፊት SaaS እንዴት መገምገም እንደሚቻል",
  "__TR_ultimate-saas-due-diligence-guide_86__": "የSaaS ኢላማን ለመገምገም ደረጃ በደረጃ የሂደት ማሳያ፦ ከመጀመሪያ የማሽተት ፍተሻ እስከ ጥልቅ የተጠቃሚ መሰናበቻ ትንተና ድረስ።",
  "__TR_ultimate-saas-due-diligence-guide_87__": "ሂደቱን ይማሩ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_88__": "ለገዢዎች Churn Lens",
  "__TR_ultimate-saas-due-diligence-guide_89__": "Churn Lens እንደ ገዢ-ወገን መሳሪያ እንዴት እንደሚሰራ፦ ምን አይነት መለኪያዎች እንደሚያሰላ፣ ምን አይነት የCSV ቅርጸት እንደሚፈልጉ እና የመጀመሪያ ሪፖርትዎን እንዴት መተርጎም እንደሚችሉ።",
  "__TR_ultimate-saas-due-diligence-guide_90__": "መሳሪያውን ይመልከቱ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_91__": "የገዢ-ወገን የአደጋ ግምገማ መሳሪያ",
  "__TR_ultimate-saas-due-diligence-guide_92__": "ካፒታል ከመፍጠርዎ በፊት የተጠቃሚ መሰናበቻን፣ ማከማቸትን፣ የገቢ ጥራትን እና የእድገት አቅጣጫን ለመገምገም የተዋቀረ ማዕቀፍ።",
  "__TR_ultimate-saas-due-diligence-guide_93__": "አደጋን ይገምግሙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_94__": "የዓመታዊ እቅድ የተጠቃሚ መሰናበቻ አደጋ ትንተና",
  "__TR_ultimate-saas-due-diligence-guide_95__": "የSaaS ንግድ መግዛት መመሪያ",
  "__TR_ultimate-saas-due-diligence-guide_96__": "ለገዢዎች Churn Lens",
  "__TR_ultimate-saas-due-diligence-guide_97__": "የተሟላ የSaaS ተገቢ ትጋት ዝርዝር",
  "__TR_ultimate-saas-due-diligence-guide_98__": "የደንበኛ ማከማቸት አደጋ",
  "__TR_ultimate-saas-due-diligence-guide_99__": "ነፃ የተጠቃሚ መሰናበቻ ኦዲት ዝርዝር",
  "__TR_ultimate-saas-due-diligence-guide_100__": "የተደበቀ የተጠቃሚ መሰናበቻ፦ ሻጮች የማይነግሩዎት ነገር",
  "__TR_ultimate-saas-due-diligence-guide_101__": "ከመግዛትዎ በፊት SaaS እንዴት መገምገም እንደሚቻል",
  "__TR_ultimate-saas-due-diligence-guide_102__": "የማይንቀሳቀሱ የሚከፈልባቸው መለያዎች — ጸጥ ያለ መሰናበቻ",
  "__TR_ultimate-saas-due-diligence-guide_103__": "የምርት ስም ማቆያ ከገቢ መሰናበቻ ጋር",
  "__TR_ultimate-saas-due-diligence-guide_104__": "MRR ከገቢ ጥራት ጋር",
  "__TR_ultimate-saas-due-diligence-guide_105__": "ለገዢዎች የMRR ማሽቆልቆል ትንተና",
  "__TR_ultimate-saas-due-diligence-guide_106__": "የSaaS ግዢ ቀይ ባንዲራዎች",
  "__TR_ultimate-saas-due-diligence-guide_107__": "የSaaS ገዢ-ወገን የአደጋ ግምገማ",
  "__TR_ultimate-saas-due-diligence-guide_108__": "የSaaS የተጠቃሚ መሰናበቻ መጠን መለኪያዎች በኢንዱስትሪ",
  "__TR_ultimate-saas-due-diligence-guide_109__": "የSaaS የገቢ መሰናበቻ አስሊ",
  "__TR_ultimate-saas-due-diligence-guide_110__": "የSaaS የገቢ ማከማቸት አደጋ",
  "__TR_ultimate-saas-due-diligence-guide_111__": "የSaaS የገቢ ጥራት ውጤት ተብራርቷል",
  "__TR_ultimate-saas-due-diligence-guide_112__": "ቀጣዩን ስምምነትዎን በገዢው ጥቅም ይጀምሩ",
  "__TR_ultimate-saas-due-diligence-guide_113__": "ነፃ የማረጋገጫ ዝርዝሩን ያግኙ &rarr;",
  "__TR_ultimate-saas-due-diligence-guide_114__": "ዋጋ አሰጣጥ",
  "__TR_ultimate-saas-due-diligence-guide_115__": "የመስራች ታሪክ",
  "__TR_ultimate-saas-due-diligence-guide_116__": "ማኒፌስቶ",
  "__TR_ultimate-saas-due-diligence-guide_117__": "አጋሮች",
  "__TR_ultimate-saas-due-diligence-guide_118__": "ነጻ የተግባር ዝርዝር",
  "__TR_ultimate-saas-due-diligence-guide_119__": "ትዊተር / ኤክስ",
  "__TR_ultimate-saas-due-diligence-guide_120__": "ሊንክድኢን"
}