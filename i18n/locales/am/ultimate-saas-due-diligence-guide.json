{
  "__TR_ultimate-saas-due-diligence-guide_0__": "የመጨረሻው የSaaS ትጋት ምርመራ መመሪያ (2026) — Churn Lens",
  "__TR_ultimate-saas-due-diligence-guide_1__": "ሙሉው የገዢ-ጎን የSaaS ትጋት ምርመራ መመሪያ። የቸርን ትንተና፣ የትኩረት አደጋ፣ የገቢ ጥራት እና የስምምነት-ተኮር ግምገማን ይማሩ። ከ17 በላይ ሀብቶች ወደ አንድ አጠቃላይ ማዕከል የተደራጁ።",
  "__TR_ultimate-saas-due-diligence-guide_2__": "የመጨረሻው የSaaS ትጋት ምርመራ መመሪያ (2026)",
  "__TR_ultimate-saas-due-diligence-guide_3__": "ሙሉው የገዢ-ጎን የSaaS ትጋት ምርመራ መመሪያ። የቸርን ትንተና፣ የትኩረት አደጋ፣ የገቢ ጥራት እና የስምምነት-ተኮር ግምገማን ይማሩ።",
  "__TR_ultimate-saas-due-diligence-guide_4__": "የመጨረሻው የSaaS ትጋት ምርመራ መመሪያ (2026)",
  "__TR_ultimate-saas-due-diligence-guide_5__": "ሙሉ የገዢ-ጎን የSaaS ትጋት ምርመራ መመሪያ። ከ17 በላይ ሀብቶች በርዕስ የተደራጁ።",
  "__TR_ultimate-saas-due-diligence-guide_6__": "Churn Lens",
